# Copy to .env and adjust for your environment
# DATABASE_URL - MySQL connection string (default: local dev)
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/game_sila_misly

# SECRET_KEY - JWT signing key (required in production)
SECRET_KEY=your-secret-key-change-this-in-production

# CORS_ORIGINS - Comma-separated allowed origins, or * for allow-all
# Example: https://quze.example.com,https://app.quze.com
CORS_ORIGINS=*
